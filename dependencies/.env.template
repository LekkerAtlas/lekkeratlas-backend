# ================================
# Local dependency config
# ================================

COMPOSE_PROJECT_NAME=lekkeratlas-dev

# ================================
# Main application Postgres
# ================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lekkeratlas
POSTGRES_PORT=5432

# Values used by Spring Boot when started through just
DATASOURCE_URL=jdbc:postgresql://localhost:5432/lekkeratlas
DATASOURCE_USERNAME=${POSTGRES_USER}
DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# ================================
# RabbitMQ
# ================================

RABBITMQ_DEFAULT_USER=rabbitmq
RABBITMQ_DEFAULT_PASS=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Values used by Spring Boot when started through just
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=rabbitmq
SPRING_RABBITMQ_PASSWORD=rabbitmq

# ================================
# Custom Authentik
# ================================

AUTHENTIK_HTTP_PORT=9000
AUTHENTIK_HTTPS_PORT=9443

# ================================
# Authentik database
# ================================

AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=authentik
AUTHENTIK_POSTGRES_DB=authentik

# ================================
# Authentik runtime config
# ================================

AUTHENTIK_SECRET_KEY=local-dev-secret-key-change-me
AUTHENTIK_ERROR_REPORTING__ENABLED=false

AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
AUTHENTIK_BOOTSTRAP_TOKEN=local-dev-token

# ================================
# LekkerAtlas Authentik blueprint config
# ================================

AUTHENTIK_LEKKERATLAS_FQDN=http://localhost
AUTHENTIK_LEKKERATLAS_REDIRECT_URI=http://localhost
AUTHENTIK_LEKKERATLAS_LOGOUT_URI=http://localhost
AUTHENTIK_LEKKERATLAS_WEBHOOK_FQDN=http://host.docker.internal:8080/webhooks/authentik

AUTHENTIK_WEBHOOK_SYNC_LEKKERATLAS_DB_BEARER_TOKEN=local-dev-webhook-token
AUTHENTIK_PROVIDER_FOR_LEKKERATLAS_CLIENT_SECRET=local-dev-client-secret
AUTHENTIK_RABBITMQ_CLIENT_SECRET=local-dev-rabbitmq-secret

# ================================
# Values used by SpringBoot
# ================================

SPRING_PROFILES_ACTIVE=dev

AUTHENTIK_ISSUER_URI=http://localhost:9000/application/o/lekker-atlas/
AUTHENTIK_CLIENT_ID=lekkeratlas-local

AUTHENTIK_WEBHOOK_SECRET=$AUTHENTIK_WEBHOOK_SYNC_LEKKERATLAS_DB_BEARER_TOKEN

AUTHENTIK_HOST=http://localhost:9000
AUTHENTIK_WEBHOOK_SECRET_ALLOWED_SOURCE_CIDRS=127.0.0.1/32,::1/128,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
